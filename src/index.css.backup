@import url('https://fonts.googleapis.com/css2?family=Caveat:wght@600&family=Outfit:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Plus Jakarta Sans", ui-sans-serif, system-ui, sans-serif;
  --font-display: "Outfit", sans-serif;
  --font-cursive: "Caveat", cursive;
  --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
}

body {
  background-color: #fcfbf7;
  color: #1a2530;
  font-family: var(--font-sans);
}

/* Custom scrollbar matching light warm theme */
::-webkit-scrollbar {
  width: 8px;
}
::-webkit-scrollbar-track {
  background: #f4f2ea;
}
::-webkit-scrollbar-thumb {
  background: #d4cfbe;
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: #beb8a5;
}
