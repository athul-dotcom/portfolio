      <div className="absolute inset-0 bg-[radial-gradient(#e4e1d3_1px,transparent_1px)] [background-size:24px_24px] opacity-30 pointer-events-none" />

      <div className="relative w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center z-10">
        
        {/* LEFT COLUMN: INTRO & HEADINGS */}
        <div className="lg:col-span-7 flex flex-col justify-between h-full space-y-8 md:space-y-12">
          
          <div className="space-y-6">
            {/* Recruiter Alert Pill */}
