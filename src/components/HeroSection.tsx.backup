        {/* RIGHT COLUMN: PORTRAIT IMAGE WITH PAINT SPOTS */}
        <div className="lg:col-span-5 relative flex flex-col items-center lg:items-end justify-center">
          
          {/* Subtle Tagline top-right */}
          <motion.div
