            >
              <span className="relative flex h-2 w-2">
                <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#136c5b] opacity-75"></span>
                <span className="relative inline-flex rounded-full h-2 w-2 bg-[#136c5b]"></span>
              </span>
              <span className="font-display tracking-wider uppercase text-[10px]">Open to Opportunities</span>
              <span className="text-[#136c5b]/40">|</span>
              <span className="flex items-center gap-1 font-medium">
                Ask my AI Recruiter Twin <Sparkles className="w-3 h-3 text-[#f2b32c] fill-[#f2b32c]" />
