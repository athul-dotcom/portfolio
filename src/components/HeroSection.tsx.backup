                <path d="M51.2,-64C66.5,-53.4,79.1,-38.7,83,-22C86.9,-5.3,82.1,13.5,73.5,29.9C64.9,46.3,52.5,60.4,36.9,67.6C21.3,74.9,2.5,75.4,-15.7,70.9C-33.9,66.4,-51.5,56.9,-63,42.4C-74.5,27.9,-79.9,8.4,-77.3,-9.9C-74.8,-28.1,-64.3,-45,-49.6,-55.5C-34.9,-66,-17.4,-70.2,0.4,-70.8C18.2,-71.4,36,-68.4,51.2,-64Z" transform="translate(100 100)" />
              </svg>
            </div>

            {/* Circular Framed Developer Avatar Image */}
            <motion.div
