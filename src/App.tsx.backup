        {/* Section 7: REAL-TIME RECRUITER PLAYGROUND & LIVE LOGS (PROVES FULL-STACK REPUTE) */}
        <section id="playground" className="scroll-mt-24">
          <div className="bg-white border-2 border-[#121c2c] rounded-[2.5rem] p-6 sm:p-8 relative overflow-hidden shadow-xs">
            
            <div className="flex flex-col lg:flex-row gap-6 justify-between items-start lg:items-center pb-6 border-b-2 border-[#121c2c]/10">
              <div>
                <span className="text-[10px] font-mono text-[#136c5b] uppercase tracking-widest block mb-1 font-bold">Recruiter Exclusive Console</span>
                <h2 className="text-2xl font-display font-black text-[#121c2c]">Full-Stack Live Testing Console</h2>
                <p className="text-[#5c6874] text-xs mt-1">Submit a message via the form below or chat with the AI Twin to see state updates trigger instantly on this live panel.</p>
              </div>
              <div className="flex items-center gap-3 bg-[#faf9f5] border border-[#dfdab8] px-4 py-2 rounded-xl text-xs font-mono font-bold shadow-xs">
                <span className="text-[#5c6874]">Live Visitors:</span>
                <strong className="text-[#136c5b] font-black">{visitorCount}</strong>
                <span className="text-[#dfdab8]">|</span>
                <span className="text-[#5c6874]">Messages Saved:</span>
                <strong className="text-[#e09e1b] font-black">{messagesReceived.length}</strong>
              </div>
            </div>

            <div className="grid grid-cols-1 lg:grid-cols-12 gap-6 mt-6">
              
              {/* Submitted message logs display */}
              <div className="lg:col-span-7 bg-[#fcfbf7] border border-[#dfdab8] p-4 sm:p-6 rounded-2xl flex flex-col justify-between min-h-[250px]">
                <div>
                  <h3 className="text-xs uppercase font-mono tracking-widest text-[#5c6874] mb-3.5 flex items-center gap-2 font-bold">
                    <span className="w-1.5 h-3 bg-[#136c5b] rounded-full" />
                    Real-time Saved Messages Log
                  </h3>

                  <div className="space-y-3 max-h-[190px] overflow-y-auto pr-1 scrollbar-thin">
                    {messagesReceived.length > 0 ? (
                      messagesReceived.map((msg, index) => (
                        <div
                          key={msg.id || index}
                          className="bg-white border-2 border-[#121c2c] p-3 rounded-xl text-xs flex flex-col gap-1 shadow-xs"
                        >
                          <div className="flex items-center justify-between text-[#5c6874] font-mono">
                            <strong>{msg.name} ({msg.email})</strong>
                            <span className="text-[9px] text-slate-400">
                              {msg.timestamp ? new Date(msg.timestamp).toLocaleTimeString() : "Just now"}
                            </span>
                          </div>
                          <p className="text-[#121c2c] mt-1 italic font-sans">"{msg.message}"</p>
                        </div>
                      ))
                    ) : (
                      <div className="p-8 text-center text-[#5c6874] italic text-xs font-mono">
                        No custom messages received yet. Submit the contact form below to seed the database!
                      </div>
                    )}
                  </div>
                </div>

                <div className="pt-4 border-t border-[#dfdab8]/50 flex justify-between items-center text-[10px] font-mono text-[#5c6874] font-bold">
                  <span>DB Type: In-memory Array (Server API)</span>
                  <span className="text-[#136c5b] flex items-center gap-1.5">
                    <span className="w-2.5 h-2.5 rounded-full bg-[#136c5b] animate-pulse" />
                    SYNCED WITH EXPRESS SERVER
                  </span>
                </div>
              </div>

              {/* Developer Environment info */}
              <div className="lg:col-span-5 bg-[#faf9f5] border border-[#dfdab8] p-4 sm:p-6 rounded-2xl flex flex-col justify-between">
                <div>
                  <h3 className="text-xs uppercase font-mono tracking-widest text-[#5c6874] mb-3 flex items-center gap-2 font-bold">
                    <span className="w-1.5 h-3 bg-[#e09e1b] rounded-full" />
                    Portfolio Environment Coordinates
                  </h3>

                  <div className="space-y-2 text-xs font-mono text-[#121c2c] bg-white p-3.5 rounded-xl border border-[#dfdab8] font-bold shadow-xs">
                    <div className="flex justify-between">
                      <span className="text-[#5c6874]">Node Environment:</span>
                      <span className="text-[#136c5b]">production</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-[#5c6874]">Vite Build Port:</span>
                      <span className="text-[#e09e1b]">3000 (Proxy)</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-[#5c6874]">Framework Runtime:</span>
                      <span className="text-[#136c5b]">React 19 / ESM</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-[#5c6874]">Server Clock:</span>
                      <span className="text-rose-600 text-[10px] font-mono truncate max-w-[150px]">{currentUtcTime}</span>
                    </div>
                  </div>
                </div>

                <div className="pt-4 border-t border-[#dfdab8]/50">
                  <p className="text-[10px] text-[#5c6874] leading-relaxed">
                    This single-page React app uses a custom Express Node.js server. The portfolio builds on Vite & uses standard esbuild bundles for fast startup.
                  </p>
                </div>
              </div>

            </div>
          </div>
        </section>

