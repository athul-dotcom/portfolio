            <button onClick={() => handleScrollToSection("experience")} className="hover:text-[#136c5b] transition-colors cursor-pointer relative py-1 after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-[#136c5b] after:scale-x-0 hover:after:scale-x-100 after:transition-transform">Experience</button>
            <button onClick={() => handleScrollToSection("skills")} className="hover:text-[#136c5b] transition-colors cursor-pointer relative py-1 after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-[#136c5b] after:scale-x-0 hover:after:scale-x-100 after:transition-transform">Skills</button>
