            </div>

            {/* Interactive Contact Form (Col span 7) */}
            <div className="lg:col-span-7 bg-white border-2 border-[#121c2c] p-6 sm:p-8 rounded-[2.5rem] shadow-xs">
              <form onSubmit={handleContactSubmit} className="space-y-4">
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div className="space-y-1.5">
                    <label className="text-[10px] uppercase font-bold tracking-wider text-[#5c6874] font-mono">Your Name</label>
                    <input
                      type="text"
                      required
                      value={contactName}
                      onChange={(e) => setContactName(e.target.value)}
                      placeholder="Jane Doe"
                      className="w-full bg-[#faf9f5] border-2 border-[#121c2c] focus:border-[#136c5b] rounded-xl px-4 py-2.5 text-sm text-[#121c2c] focus:outline-none focus:bg-white transition-all placeholder:text-[#dfdab8]"
                    />
                  </div>
                  <div className="space-y-1.5">
                    <label className="text-[10px] uppercase font-bold tracking-wider text-[#5c6874] font-mono">Your Email</label>
                    <input
                      type="email"
                      required
                      value={contactEmail}
                      onChange={(e) => setContactEmail(e.target.value)}
                      placeholder="jane@company.com"
                      className="w-full bg-[#faf9f5] border-2 border-[#121c2c] focus:border-[#136c5b] rounded-xl px-4 py-2.5 text-sm text-[#121c2c] focus:outline-none focus:bg-white transition-all placeholder:text-[#dfdab8]"
                    />
                  </div>
                </div>

                <div className="space-y-1.5">
                  <label className="text-[10px] uppercase font-bold tracking-wider text-[#5c6874] font-mono">Message / Invitation Details</label>
                  <textarea
                    required
                    rows={4}
                    value={contactMessage}
                    onChange={(e) => setContactMessage(e.target.value)}
                    placeholder="We'd love to invite you for a technical assessment and interview for our Software Engineer position..."
                    className="w-full bg-[#faf9f5] border-2 border-[#121c2c] focus:border-[#136c5b] rounded-xl px-4 py-2.5 text-sm text-[#121c2c] focus:outline-none focus:bg-white transition-all placeholder:text-[#dfdab8] resize-none"
                  />
                </div>

                {submitSuccess && (
                  <div className="p-3 bg-emerald-50 border border-emerald-100 rounded-xl text-emerald-800 text-xs flex items-center gap-2 font-bold font-mono">
                    <Check className="w-4 h-4 shrink-0 text-emerald-600" />
                    <span>{submitSuccess}</span>
                  </div>
                )}

                <button
                  type="submit"
                  disabled={isSubmitting}
                  className="w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-[#136c5b] hover:bg-[#0f5446] text-white font-display font-black rounded-xl text-sm transition-all shadow-md disabled:opacity-50 cursor-pointer active:scale-98"
                >
                  <Send className="w-4 h-4" />
                  <span>{isSubmitting ? "Sending..." : "Submit Message To Active Live Logs"}</span>
                </button>
              </form>
            </div>

          </div>
        </section>

      </main>

      {/* Recruiter Command Hint Footer */}
      <footer className="max-w-7xl mx-auto px-6 md:px-12 mt-20 pt-8 border-t-2 border-[#dfdab8]/50 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div className="flex items-center gap-4 text-xs text-[#5c6874] font-bold font-display">
          <span>© 2026 Athul K R. All rights reserved.</span>
          <span>•</span>
          <span>Kochi, Kerala, India</span>
        </div>

        <div className="flex items-center gap-2 text-[10px] text-[#5c6874] font-mono bg-[#f2eede] border border-[#dfdab8] px-3.5 py-1.5 rounded-lg shadow-xs font-bold">
          <span className="bg-white border border-[#dfdab8] px-1 py-0.5 rounded text-[9px]">⌘</span>
          <span className="bg-white border border-[#dfdab8] px-1 py-0.5 rounded text-[9px]">K</span>
          <span>to access developer CLI palette</span>
        </div>
      </footer>

      {/* Persistent Back-to-Top / AI Twin Trigger Bubble */}
      <div className="fixed bottom-6 right-6 z-40 flex flex-col gap-2.5 items-end">
        {/* Quick Back-to-Top */}
        <button
          onClick={() => handleScrollToSection("portfolio-app")}
          className="p-3 bg-white border-2 border-[#121c2c] hover:bg-[#faf9f5] rounded-xl text-[#121c2c] transition-all shadow-md text-xs font-mono font-bold cursor-pointer"
          title="Back to Top"
        >
          ↑ Top
        </button>

        {/* AI Twin Trigger Bubble */}
        <button
          onClick={() => setCopilotOpen(true)}
          className="p-4 bg-[#136c5b] hover:bg-[#0f5446] rounded-full text-white transition-all shadow-xl hover:scale-105 active:scale-95 group relative cursor-pointer"
          title="Open AI Recruiter Twin"
        >
          <Bot className="w-6 h-6" />
          <span className="absolute right-full mr-2.5 top-1/2 -translate-y-1/2 bg-white border-2 border-[#121c2c] text-[#121c2c] text-[10px] px-2.5 py-1 rounded-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none font-display font-extrabold shadow-md">
            Ask my AI Twin anything
          </span>
        </button>
      </div>

      {/* AICopilot Drawer */}
      <AICopilot isOpen={copilotOpen} onClose={() => setCopilotOpen(false)} />

      {/* Command Palette */}
      <CommandPalette
        isOpen={paletteOpen}
        onClose={() => setPaletteOpen(false)}
        onOpenCopilot={() => setCopilotOpen(true)}
        onScrollToSection={handleScrollToSection}
      />
    </div>
  );
}
