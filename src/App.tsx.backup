                  className={`px-4 py-2 rounded-full capitalize font-display font-black transition-all cursor-pointer ${
                    activeProjectTab === tab
                      ? "bg-[#136c5b] text-white shadow-xs"
                      : "text-[#5c6874] hover:text-[#121c2c]"
                  }`}
                >
                  {tab}
                </button>
              ))}
            </div>
          </div>

          {/* Premium Portfolio Case cards matching image aesthetic */}
          <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
            {filteredProjects.map((project) => (
              <div
                key={project.id}
                id={`project-card-${project.id}`}
                className="bg-white border-2 border-[#121c2c] rounded-[2.5rem] overflow-hidden flex flex-col justify-between shadow-xs hover:-translate-y-1 transition-transform duration-300 group"
              >
                {/* Header block with vivid custom color reflecting mockup in image */}
                <div className={`p-8 ${project.colorTheme} text-white relative min-h-[180px] flex flex-col justify-between`}>
                  <div className="absolute top-4 right-4 bg-white/20 text-[10px] font-mono uppercase tracking-widest px-3 py-1 rounded-full font-bold">
                    {project.type}
                  </div>
                  
                  <div className="space-y-1">
                    <h4 className="text-xs uppercase font-mono tracking-widest text-white/85 font-semibold">Case Study Overview</h4>
                    <h3 className="text-2xl font-display font-black leading-tight">{project.title}</h3>
                  </div>

                  <p className="text-xs text-white/90 leading-relaxed font-medium line-clamp-2 max-w-md">
                    {project.description}
                  </p>
                </div>

                {/* Content body */}
                <div className="p-8 space-y-6">
                  
                  <p className="text-xs text-[#5c6874] leading-relaxed bg-[#faf9f5] border border-[#dfdab8] p-4 rounded-2xl italic">
                    "{project.longDescription}"
                  </p>

                  <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {/* Challenge Box */}
                    <div className="p-3.5 bg-red-50 border border-red-100 rounded-xl">
                      <p className="text-[10px] uppercase font-bold text-red-700 font-mono tracking-wider">Challenge Faced</p>
                      <p className="text-xs text-[#5c6874] mt-1">{project.challenges}</p>
                    </div>

                    {/* Solution Box */}
                    <div className="p-3.5 bg-emerald-50 border border-emerald-100 rounded-xl">
                      <p className="text-[10px] uppercase font-bold text-emerald-700 font-mono tracking-wider">Solution Deployed</p>
                      <p className="text-xs text-[#5c6874] mt-1">{project.solutions}</p>
                    </div>
                  </div>

                  {/* Bullet Highlights */}
                  <div className="space-y-2">
                    <p className="text-[10px] uppercase font-bold text-[#5c6874] font-mono tracking-wider">Key Features Delivered:</p>
                    <div className="grid grid-cols-1 sm:grid-cols-2 gap-2">
                      {project.features.map(f => (
                        <div key={f} className="flex items-center gap-2 text-xs text-[#121c2c] font-medium">
                          <span className="w-1.5 h-1.5 rounded-full bg-[#136c5b]" />
                          <span>{f}</span>
                        </div>
                      ))}
                    </div>
                  </div>

                  {/* Tech stack */}
                  <div className="flex flex-wrap gap-1.5 pt-4 border-t border-[#121c2c]/10">
                    {project.techStack.map(t => (
                      <span key={t} className="text-[10px] font-mono font-bold text-[#121c2c] bg-[#faf9f5] border border-[#dfdab8]/60 px-2 py-0.5 rounded">
                        {t}
                      </span>
                    ))}
                  </div>

                  {/* Links footer */}
                  <div className="flex items-center justify-between pt-2">
                    <a
                      href={project.githubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      className="inline-flex items-center gap-1.5 text-xs font-display font-bold text-[#5c6874] hover:text-[#121c2c] transition-colors"
                    >
                      <Github className="w-4 h-4" />
                      <span>Codebase</span>
                    </a>

                    <button
                      onClick={() => setSelectedProject(project)}
                      className="inline-flex items-center gap-1 text-xs font-display font-black text-[#136c5b] hover:underline cursor-pointer"
                    >
                      <span>Explore Case Study</span>
                      <ArrowRight className="w-4 h-4" />
                    </button>
                  </div>

                </div>

              </div>
            ))}
          </div>

          {/* Project Details Modal (Lightbox dialog styled to match warm theme) */}
          {selectedProject && (
            <div id="project-lightbox" className="fixed inset-0 z-50 flex items-center justify-center p-4">
              <div className="fixed inset-0 bg-[#121c2c]/65 backdrop-blur-xs" onClick={() => setSelectedProject(null)} />
              <div className="bg-[#faf9f5] border-2 border-[#121c2c] rounded-[2.5rem] w-full max-w-2xl p-6 sm:p-8 z-10 relative overflow-hidden max-h-[90vh] overflow-y-auto shadow-2xl">
                <button
                  onClick={() => setSelectedProject(null)}
                  className="absolute top-4 right-4 text-[#5c6874] hover:text-[#121c2c] p-2 rounded-full border border-[#dfdab8] hover:bg-white bg-transparent transition-all font-bold"
                >
                  ✕
                </button>

                <span className="text-[10px] font-mono text-[#e09e1b] uppercase tracking-widest font-extrabold">{selectedProject.type} Case Study</span>
                <h3 className="text-2xl md:text-3xl font-display font-black text-[#121c2c] mt-2 mb-4">{selectedProject.title}</h3>

                <div className="space-y-6 text-sm text-[#5c6874] leading-relaxed">
                  <div>
                    <h4 className="text-xs font-mono font-bold text-[#121c2c] uppercase tracking-wider mb-2">Summary & Architecture</h4>
                    <p>{selectedProject.longDescription}</p>
                  </div>

                  <div>
                    <h4 className="text-xs font-mono font-bold text-[#121c2c] uppercase tracking-wider mb-2">Core Engineering Details</h4>
                    <p>Both web and mobile versions communicate efficiently to serve student-faculty workloads. The web portal enforces strict session authentication, and the companion app integrates offline data layers to guarantee seamless usage on the go.</p>
                  </div>

                  <div>
                    <h4 className="text-xs font-mono font-bold text-[#121c2c] uppercase tracking-wider mb-2">Key Features Highlighted</h4>
                    <ul className="list-disc list-inside space-y-1 text-[#5c6874]">
                      {selectedProject.features.map((f) => (
                        <li key={f}>{f}</li>
                      ))}
                    </ul>
                  </div>

                  <div className="flex flex-wrap gap-2.5 pt-5 border-t border-[#dfdab8]/50">
                    <a
                      href={selectedProject.githubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      className="px-5 py-2.5 bg-white border-2 border-[#121c2c] text-[#121c2c] rounded-full text-xs font-display font-black flex items-center gap-2 hover:bg-[#faf9f5] transition-colors"
                    >
                      <Github className="w-4 h-4" />
                      <span>View GitHub Repository</span>
                    </a>
                    <button
                      onClick={() => {
                        setSelectedProject(null);
                        setCopilotOpen(true);
                      }}
                      className="px-5 py-2.5 bg-[#136c5b] text-white rounded-full text-xs font-display font-black flex items-center gap-2 hover:bg-[#0f5446] transition-colors shadow-sm"
                    >
                      <Bot className="w-4 h-4" />
                      <span>Ask AI Twin about this project</span>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          )}
        </section>

        {/* Section 5: STYLED SKILLS MATRIX */}
        <section id="skills" className="scroll-mt-24">
          <div className="flex flex-col md:flex-row md:items-end justify-between border-b-2 border-[#121c2c] pb-6 mb-12">
            <div>
              <span className="text-[#136c5b] font-mono tracking-widest uppercase text-xs font-extrabold block mb-2">Qualified Stack</span>
              <h2 className="text-3xl md:text-4xl lg:text-5xl font-display font-black text-[#121c2c]">
                Technical Ecosystem
              </h2>
            </div>
            <div className="text-xs font-mono font-bold text-[#5c6874] uppercase tracking-widest mt-2 md:mt-0">
              Proficient developer capabilities
            </div>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            {SKILL_CATEGORIES.map((cat, idx) => (
              <div
                key={idx}
                id={`skill-cat-${idx}`}
                className="bg-white border-2 border-[#121c2c] p-6 rounded-[2rem] flex flex-col justify-between shadow-xs"
              >
                <div>
                  <h3 className="text-xs font-mono font-bold uppercase tracking-wider text-[#121c2c] mb-6 flex items-center gap-2">
                    <span className="w-1.5 h-4 bg-[#136c5b] rounded-full" />
                    {cat.title}
                  </h3>

                  <div className="space-y-4">
                    {cat.skills.map((skill) => (
                      <div key={skill.name} className="space-y-1.5">
                        <div className="flex justify-between text-xs font-bold">
                          <span className="text-[#121c2c]">{skill.name}</span>
