                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                <div className="pt-6 mt-6 border-t border-[#dfdab8]/50 flex justify-between items-center text-[10px] text-[#5c6874] font-mono">
                  <span>Stack {idx + 1} of 3</span>
                  <span>Responsive system designs</span>
                </div>
              </div>
            ))}
          </div>

          {/* Certifications Row (Light Themed) */}
          <div className="mt-12">
            <h3 className="text-xs uppercase font-bold tracking-widest text-[#5c6874] mb-5 font-mono">Industry Certifications</h3>
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              {CERTIFICATIONS.map((cert, idx) => (
                <div
