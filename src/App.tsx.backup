        {/* Section 2: "What do I help?" (About & Services Bento inspired from image) */}
        <section id="services" className="scroll-mt-24">
          <div className="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            
            {/* Left Col: Three elegant icon-badge list cards */}
            <div className="lg:col-span-5 space-y-5">
              
              {/* Card 1: Website Design */}
              <div className="bg-white border-2 border-[#121c2c] p-6 rounded-[2rem] flex items-center gap-5 shadow-xs hover:-translate-y-1 transition-transform duration-300">
                <div className="w-14 h-14 rounded-full bg-[#136c5b] flex items-center justify-center text-white shrink-0">
                  <Globe className="w-6 h-6" />
                </div>
                <div>
                  <h3 className="text-lg font-display font-extrabold text-[#121c2c]">Website Design</h3>
                  <p className="text-xs text-[#5c6874] mt-1">PHP / MySQL scratch architectures, role-based modules, and dynamic database admin dashboards.</p>
                </div>
              </div>

              {/* Card 2: Mobile App Design */}
              <div className="bg-white border-2 border-[#121c2c] p-6 rounded-[2rem] flex items-center gap-5 shadow-xs hover:-translate-y-1 transition-transform duration-300">
                <div className="w-14 h-14 rounded-full bg-[#f2b32c] flex items-center justify-center text-[#121c2c] shrink-0">
                  <Smartphone className="w-6 h-6" />
                </div>
                <div>
                  <h3 className="text-lg font-display font-extrabold text-[#121c2c]">Mobile App Design</h3>
                  <p className="text-xs text-[#5c6874] mt-1">React Native student-faculty workflows, offline-first assets, and optimized payload deliveries.</p>
                </div>
              </div>

              {/* Card 3: Brand Identity & DB Normalized schemas */}
              <div className="bg-white border-2 border-[#121c2c] p-6 rounded-[2rem] flex items-center gap-5 shadow-xs hover:-translate-y-1 transition-transform duration-300">
                <div className="w-14 h-14 rounded-full bg-[#e06b5a] flex items-center justify-center text-white shrink-0">
                  <Database className="w-6 h-6" />
                </div>
                <div>
                  <h3 className="text-lg font-display font-extrabold text-[#121c2c]">Database & Security</h3>
