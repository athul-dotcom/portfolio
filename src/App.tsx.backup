                    <span className="text-[10px] text-[#5c6874] font-mono">{cert.date}</span>
                    <span className="w-2 h-2 bg-[#136c5b] rounded-full" />
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* Section 6: ELITE ACHIEVEMENTS (SSB & KHO-KHO) */}
        <section id="achievements" className="scroll-mt-24">
          <div className="flex flex-col md:flex-row md:items-end justify-between border-b-2 border-[#121c2c] pb-6 mb-12">
