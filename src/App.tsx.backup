            </div>

            {/* National Level Athlete Card */}
            <div id="achievement-kho-kho" className="bg-white border-2 border-[#121c2c] p-6 sm:p-8 rounded-[2.5rem] flex flex-col justify-between relative overflow-hidden group shadow-xs">
              
              <div>
                <span className="text-[10px] font-mono text-[#e09e1b] bg-[#f2b32c]/10 border border-[#f2b32c]/20 px-3 py-1 rounded-full uppercase tracking-wider font-extrabold">
