          <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            {/* SSB Recommendation - Highlighted Card */}
            <div id="achievement-ssb" className="lg:col-span-2 bg-white border-2 border-[#121c2c] p-6 sm:p-8 rounded-[2.5rem] flex flex-col justify-between relative group overflow-hidden shadow-xs">
              
              <div>
                <span className="text-[10px] font-mono text-[#136c5b] bg-[#136c5b]/10 border border-[#136c5b]/20 px-3 py-1 rounded-full uppercase tracking-wider font-extrabold">
